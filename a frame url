<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>A-Frame Scene</title>

    <!-- A-Frame -->
    <script src="https://aframe.io/releases/1.5.0/aframe.min.js"></script>

    <!-- Optional: nice sky/ground environment -->
    <script src="https://cdn.jsdelivr.net/npm/aframe-environment-component@1.3.2/dist/aframe-environment-component.min.js"></script>
  </head>

  <body style="margin:0;">
    <a-scene renderer="colorManagement: true;" background="color: #0b0f18">

      <!-- Preload assets (models, textures) -->
      <a-assets timeout="10000">
        <a-asset-item id="templeModel" src="assets/models/temple.glb"></a-asset-item>
        <a-asset-item id="lanternModel" src="assets/models/lantern.glb"></a-asset-item>

        <!-- Example texture if you want it -->
        <!-- <img id="stoneTex" src="assets/textures/stone.jpg" /> -->
      </a-assets>

      <!-- Lighting -->
      <a-entity light="type: ambient; intensity: 0.6; color: #ffffff"></a-entity>
      <a-entity light="type: directional; intensity: 0.9; color: #ffffff"
                position="2 6 3"></a-entity>

      <!-- Camera + controls -->
      <a-entity position="0 1.6 5">
        <a-camera wasd-controls look-controls></a-camera>
      </a-entity>

      <!-- Ground / environment (optional) -->
      <a-entity environment="preset: forest; groundColor: #1b2230; skyColor: #0b0f18; fog: 0.7"></a-entity>

      <!-- Your models -->
      <a-entity gltf-model="#templeModel"
                position="0 0 -4"
                rotation="0 180 0"
                scale="1 1 1"></a-entity>

      <a-entity gltf-model="#lanternModel"
                position="1 0.5 -2"
                rotation="0 30 0"
                scale="0.6 0.6 0.6"></a-entity>

      <!-- Simple geometry placeholder (helps you see scale) -->
      <a-box position="-1 0.5 -2" depth="0.5" height="1" width="0.5" color="#4466ff" opacity="0.35"></a-box>

    </a-scene>
  </body>
</html>
